# App URLs / environment
APP_ENV=local
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marketing_db

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

# Generation settings
MAX_CONCURRENT_GENERATIONS=5
GENERATION_TIMEOUT_SECONDS=30

# Auth (JWT)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Social token encryption
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SOCIAL_TOKEN_ENCRYPTION_KEY=

# X (Twitter) OAuth 2.0 — https://developer.twitter.com/en/portal
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:8000/api/v1/integrations/x/callback
X_INTEGRATION_ENABLED=true
X_PUBLISH_RATE_LIMIT_PER_HOUR=30
X_SCHEDULE_RATE_LIMIT_PER_HOUR=60
X_MAX_SCHEDULED_POSTS_PER_USER=100
X_PUBLISH_MAX_ATTEMPTS=3

# Vercel Cron
CRON_SECRET=

# LinkedIn OAuth 2.0 — https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/v1/social/callback/linkedin
LINKEDIN_API_VERSION=202504
